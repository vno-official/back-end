{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start All Microservices",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Start Service Discovery",
                "Open Eureka Dashboard",
                "Start Config Server",
                "Start Auth Service",
                "Start User Service",
                "Start Organization Service",
                "Start Note Service",
                "Start Notification Service",
                "Start Tag Service",
                "Start API Gateway"
            ],
            "group": "build",
            "problemMatcher": []
        },
        /* --------------------------------------------------------------- */
        /*  SERVICE DISCOVERY (Eureka)                                    */
        /* --------------------------------------------------------------- */
        {
            "label": "Start Service Discovery",
            "type": "shell",
            "command": "./gradlew.bat",
            "args": [
                ":service-discovery:bootRun"
            ],
            "isBackground": true,
            "group": "build",
            "problemMatcher": [
                {
                    "owner": "spring",
                    "pattern": [
                        {
                            "regexp": "^.*$",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": ".*Started ServiceDiscoveryApplication.*",
                        "endsPattern": ".*"
                    }
                }
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            }
        },
        {
            "label": "Open Eureka Dashboard",
            "type": "shell",
            "command": "powershell",
            "args": [
                "Start-Process",
                "http://localhost:8761"
            ],
            "dependsOn": "Start Service Discovery",
            "problemMatcher": [],
            "presentation": {
                "reveal": "never",
                "panel": "shared"
            }
        },
