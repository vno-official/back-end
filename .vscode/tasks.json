        /* --------------------------------------------------------------- */
        /*  STOP / CLEAN                                                   */
        /* --------------------------------------------------------------- */
        {
            "label": "Stop All Services",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "for /f \"tokens=1\" %a in ('jps -l ^| find \"com.vno\"') do taskkill /PID %a /F"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
